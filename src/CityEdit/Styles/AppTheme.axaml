<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- Глобальная тема CityEdit: минималистичный    -->
    <!-- чёрно-белый дизайн, вдохновлённый CREST      -->
    <!-- ============================================ -->

    <!-- Ресурсы цветовой палитры -->
    <Style>
        <Style.Resources>
            <SolidColorBrush x:Key="BgPrimary" Color="#0A0A0A"/>
            <SolidColorBrush x:Key="BgCard" Color="#151515"/>
            <SolidColorBrush x:Key="BgInput" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="BgHover" Color="#222222"/>
            <SolidColorBrush x:Key="BorderDefault" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="BorderFocus" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#808080"/>
            <SolidColorBrush x:Key="TextMuted" Color="#4A4A4A"/>
            <SolidColorBrush x:Key="AccentWhite" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentDark" Color="#000000"/>
            <SolidColorBrush x:Key="StatusSuccess" Color="#C0C0C0"/>
            <SolidColorBrush x:Key="StatusError" Color="#CC3333"/>
            <SolidColorBrush x:Key="ToggleOn" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ToggleOff" Color="#333333"/>
            <SolidColorBrush x:Key="SidebarBg" Color="#0F0F0F"/>
            <SolidColorBrush x:Key="SidebarActive" Color="#1A1A1A"/>

            <x:Double x:Key="FontSizeSmall">11</x:Double>
            <x:Double x:Key="FontSizeNormal">13</x:Double>
            <x:Double x:Key="FontSizeMedium">15</x:Double>
            <x:Double x:Key="FontSizeLarge">18</x:Double>
            <x:Double x:Key="FontSizeXLarge">24</x:Double>
            <x:Double x:Key="FontSizeTitle">32</x:Double>
        </Style.Resources>
    </Style>

    <!-- Глобальный стиль окна -->
    <Style Selector="Window">
        <Setter Property="Background" Value="#0A0A0A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontFamily" Value="Inter, avares://Avalonia.Fonts.Inter/Assets#Inter"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Стиль текстового блока -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Стиль заголовков (uppercase, tracking) -->
    <Style Selector="TextBlock.heading">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#808080"/>
    </Style>

    <Style Selector="TextBlock.title">
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="FontSize" Value="28"/>
    </Style>

    <Style Selector="TextBlock.subtitle">
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#808080"/>
    </Style>

    <!-- Стиль кнопок -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="#333333"/>
    </Style>

    <!-- Кнопка-акцент (белая) -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="BorderBrush" Value="#FFFFFF"/>
    </Style>

    <!-- Force black text inside accent buttons -->
    <Style Selector="Button.accent /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#000000"/>
    </Style>

    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="#E0E0E0"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
    </Style>

    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#000000"/>
    </Style>

    <Style Selector="Button.accent:pressed">
        <Setter Property="Background" Value="#CCCCCC"/>
    </Style>

    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#000000"/>
    </Style>

    <!-- Кнопка-опасность (разрушительное действие) -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#1A0000"/>
        <Setter Property="BorderBrush" Value="#CC3333"/>
        <Setter Property="Foreground" Value="#CC3333"/>
    </Style>

    <Style Selector="Button.danger:pointerover">
        <Setter Property="Background" Value="#2A0000"/>
    </Style>

    <!-- Кнопка боковой навигации -->
    <Style Selector="Button.nav">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#4A4A4A"/>
    </Style>

    <Style Selector="Button.nav:pointerover">
        <Setter Property="Background" Value="#1A1A1A"/>
        <Setter Property="Foreground" Value="#808080"/>
    </Style>

    <Style Selector="Button.nav.active">
        <Setter Property="Background" Value="#1A1A1A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="2,0,0,0"/>
        <Setter Property="BorderBrush" Value="#FFFFFF"/>
    </Style>

    <!-- Поле ввода текста -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="#FFFFFF"/>
        <Setter Property="SelectionBrush" Value="#333333"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#FFFFFF"/>
    </Style>

    <!-- Числовое поле -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Переключатель (ToggleSwitch) -->
    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="OnContent" Value=""/>
        <Setter Property="OffContent" Value=""/>
    </Style>

    <!-- Чекбокс -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ListBox -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#151515"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="#1E1E1E"/>
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="#2A2A2A"/>
    </Style>

    <!-- Разделитель -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- ScrollViewer -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Карточка (Border) -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="#151515"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.card:pointerover">
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
    </Style>

</Styles>
