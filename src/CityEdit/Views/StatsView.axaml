<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CityEdit.ViewModels"
             xmlns:items="using:CityEdit.ViewModels.Items"
             x:Class="CityEdit.Views.StatsView"
             x:DataType="vm:MainWindowViewModel">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Classes="heading" Text="STATISTICS" Margin="0,0,0,16"/>

        <Border Classes="card">
            <ItemsControl ItemsSource="{Binding Stats}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="items:StatItemViewModel">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <TextBlock Text="{Binding DisplayName}"
                                       VerticalAlignment="Center" FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,0,8,0"/>
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Value}"
                                           Minimum="0" Maximum="99999999"
                                           MinWidth="120" FontSize="13"
                                           HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DockPanel>
</UserControl>
